local function CreateSlider(txt, min, max, start, callback)
    local f = Instance.new("Frame", Container); f.Size = UDim2.new(1, 0, 0, 40); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 15); l.Text = txt..": "..start; l.TextColor3 = Theme.Text; l.Font = Enum.Font.Gotham; l.TextSize = 10; l.BackgroundTransparency = 1
    local bg = Instance.new("Frame", f); bg.Size = UDim2.new(1, 0, 0, 4); bg.Position = UDim2.new(0, 0, 0.7, 0); bg.BackgroundColor3 = Theme.Accent
    local p = Instance.new("Frame", bg); p.Size = UDim2.new(0, 10, 0, 10); p.Position = UDim2.new((start-min)/(max-min), -5, 0.5, -5); p.BackgroundColor3 = Theme.Main; Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
    
    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            local move = RunService.RenderStepped:Connect(function()
                local perc = math.clamp((UserInputService:GetMouseLocation().X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
                p.Position = UDim2.new(perc, -5, 0.5, -5)
                local val = math.floor(min + (max - min) * perc)
                l.Text = txt..": "..val; callback(val)
            end)
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then move:Disconnect() end end)
        end
    end)
end

