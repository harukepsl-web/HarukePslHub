--// --- UTILS ---
local function IsVisible(part)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LP.Character, Camera}
    local ray = Workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, params)
    return (ray and ray.Instance:IsDescendantOf(part.Parent))
end

local function GetClosestPlayer()
    local target = nil
    local dist = Config.FOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character:FindFirstChild("Head") then
            if p.Character.Humanoid.Health >= 2 then
                local head = p.Character.Head
                local pos, sc = Camera:WorldToViewportPoint(head.Position)
                local m = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if sc and m < dist then
                    if not Config.WallCheck or IsVisible(head) then dist = m; target = head end
                end
            end
        end
    end
    return target
end

local function UpdateWorld()
    local Atmo = Lighting:FindFirstChild("HarukeAtmo") or Instance.new("Atmosphere", Lighting)
    Atmo.Name = "HarukeAtmo"
    Atmo.Density = Config.WorldEffects and Config.FogDensity or 0
    Atmo.Color = Theme.Main
end

local function CreateTeleportTool()
    local tool = Instance.new("Tool")
    tool.RequiresHandle = false; tool.Name = "Haruka Teleport"
    tool.Activated:Connect(function()
        if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
            LP.Character.HumanoidRootPart.CFrame = CFrame.new((Mouse.Hit + Vector3.new(0, 3, 0)).Position)
        end
    end)
    tool.Parent = LP.Backpack
end

