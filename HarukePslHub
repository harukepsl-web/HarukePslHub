    p.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RunService.RenderStepped:Connect(function() if drag then
        local m = UserInputService:GetMouseLocation().X
        local perc = math.clamp((m - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
