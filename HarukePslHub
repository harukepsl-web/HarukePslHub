    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 20); l.Text = txt .. ": " .. startVal; l.TextColor3 = Theme.Text; l.BackgroundTransparency = 1; l.TextSize = 10
    local bg = Instance.new("Frame", f); bg.Size = UDim2.new(0.9, 0, 0, 4); bg.Position = UDim2.new(0.05, 0, 0.7, 0); bg.BackgroundColor3 = Theme.Accent
    local p = Instance.new("TextButton", bg); p.Size = UDim2.new(0, 12, 0, 12); p.Position = UDim2.new((startVal-min)/(max-min), -6, 0.5, -6); p.BackgroundColor3 = Theme.Main; p.Text = ""; Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
